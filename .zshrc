# zmodload zsh/zprof

source $HOME/.config/zsh/01-env.zsh
source $HOME/.config/zsh/02-plugins.zsh
source $HOME/.config/zsh/03-keybindings.zsh
source $HOME/.config/zsh/04-aliases.zsh
source $HOME/.config/zsh/05-functions.zsh
source $HOME/.config/zsh/06-tools.zsh

# zprof

# Added by GitButler installer
export PATH="$HOME/.local/bin:$PATH"
eval "$(but completions zsh)"
